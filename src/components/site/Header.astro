---
<header class="header" id="site-header">
  <div class="container">
    <div class="header-inner">
      <a href="/" class="header-logo" data-asset="1" data-asset-status="replaced">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="122 90 192 62" height="32" width="99" aria-label="ATN" role="img">
          <path fill="currentColor" fill-rule="nonzero" d="M 190.339844 96.117188 L 190.339844 114.816406 L 206.46875 114.816406 L 206.46875 145.542969 L 230.253906 145.542969 L 230.253906 114.816406 L 246.207031 114.816406 L 246.207031 96.117188 Z"/>
          <path fill="currentColor" fill-rule="nonzero" d="M 286.039062 96.117188 L 286.039062 118.738281 L 272.789062 96.117188 L 252.132812 96.117188 L 252.132812 145.542969 L 273.730469 145.542969 L 273.730469 130.292969 L 282.855469 145.542969 L 307.636719 145.542969 L 307.636719 96.117188 Z"/>
          <path fill="currentColor" fill-rule="nonzero" d="M 162.820312 145.542969 L 162.820312 122.917969 L 149.570312 145.542969 L 128.914062 145.542969 L 159.640625 96.117188 L 184.421875 96.117188 L 184.421875 145.542969 Z"/>
        </svg>
      </a>

      <nav aria-label="ניווט ראשי">
        <ul class="header-nav">
          <li><a href="/services">שירותים</a></li>
          <li><a href="/how-it-works">איך זה עובד</a></li>
          <li><a href="/about">אודות</a></li>
          <li><a href="/blog">בלוג</a></li>
          <li><a href="/contact">צור קשר</a></li>
        </ul>
      </nav>

      <a href="/contact" class="btn btn-primary header-cta">קבע פגישה ←</a>

      <button class="hamburger" id="hamburger" aria-label="פתח תפריט" aria-expanded="false">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </div>
</header>

<!-- Mobile nav -->
<nav class="mobile-nav" id="mobile-nav" aria-label="ניווט נייד">
  <a href="/services" class="mobile-nav-link">שירותים</a>
  <a href="/how-it-works" class="mobile-nav-link">איך זה עובד</a>
  <a href="/about" class="mobile-nav-link">אודות</a>
  <a href="/blog" class="mobile-nav-link">בלוג</a>
  <a href="/contact" class="mobile-nav-link">צור קשר</a>
  <a href="/contact" class="btn btn-primary mt-3">קבע פגישה ←</a>
</nav>

<script>
  const header = document.getElementById('site-header') as HTMLElement;
  const hamburger = document.getElementById('hamburger') as HTMLButtonElement;
  const mobileNav = document.getElementById('mobile-nav') as HTMLElement;

  // Initialize immediately: non-hero pages (Services, About, etc.) have a light
  // background, so the header must show dark text from the first frame.
  // Also handle the case where the user loads a page with a pre-existing scroll offset.
  const hasDarkHero = !!document.querySelector('.hero');
  if (!hasDarkHero || window.scrollY > 0) {
    header.classList.add('scrolled');
  }

  // Sticky header: IntersectionObserver is far cheaper than a scroll listener.
  // A 1px sentinel at the top of the page triggers when user scrolls past it.
  const sentinel = document.createElement('div');
  sentinel.setAttribute('aria-hidden', 'true');
  sentinel.style.cssText = 'position:absolute;top:0;left:0;width:1px;height:1px;pointer-events:none;';
  document.body.insertBefore(sentinel, document.body.firstChild);

  new IntersectionObserver(
    ([entry]) => header.classList.toggle('scrolled', !entry.isIntersecting),
    { threshold: 0 }
  ).observe(sentinel);

  // Hamburger toggle
  hamburger.addEventListener('click', () => {
    const isOpen = mobileNav.classList.toggle('open');
    hamburger.classList.toggle('open', isOpen);
    hamburger.setAttribute('aria-expanded', String(isOpen));
    document.body.style.overflow = isOpen ? 'hidden' : '';
  });

  // Close mobile nav on link click
  mobileNav.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      mobileNav.classList.remove('open');
      hamburger.classList.remove('open');
      hamburger.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    });
  });
</script>
