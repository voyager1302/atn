---
---
<section class="hero">
  <div class="container">
    <div class="grid-2">
      <div class="hero-text">
        <h1>דפי נחיתה שלא רק מביאים תנועה<br />אלא מייצרים פעולה</h1>
        <p>המשתמש לא רק קורא — הוא מגיב<br />והתגובה הזו היא מה שמובילה לפניות</p>
        <div class="hero-actions">
          <a href="#interactive-demo" class="btn btn-primary" data-smooth-scroll>בדוק איך זה עובד</a>
          <a href="/contact" class="btn btn-secondary">קבע פגישה</a>
        </div>
      </div>

      <div class="hero-visual" aria-hidden="true">
        <!-- Desktop: laptop/browser mockup -->
        <div class="hero-laptop-wrap">
          <div class="hero-laptop-screen">
            <div class="laptop-mini-page">
              <div class="laptop-mini-hero-bg">
                <div class="laptop-mini-nav">
                  <div class="laptop-mini-logo"></div>
                  <div class="laptop-mini-links">
                    <div class="laptop-mini-link"></div>
                    <div class="laptop-mini-link"></div>
                    <div class="laptop-mini-link"></div>
                  </div>
                </div>
                <div class="laptop-headline-line" style="width:76%"></div>
                <div class="laptop-headline-line" style="width:56%"></div>
                <div class="laptop-sub-line"></div>
                <div class="laptop-cta-pill"></div>
              </div>
              <div class="laptop-mini-content-bg">
                <div class="laptop-content-bar" style="width:82%"></div>
                <div class="laptop-content-bar" style="width:64%"></div>
                <div class="laptop-content-bar" style="width:74%"></div>
                <div class="laptop-cursor-dot"></div>
              </div>
            </div>
          </div>
          <div class="laptop-chin">
            <div class="laptop-notch"></div>
          </div>
        </div>

        <!-- Mobile: phone mockup -->
        <div class="hero-phone-mockup">
          <div class="phone-screen-line"></div>
          <div class="phone-screen-line"></div>
          <div class="phone-screen-line"></div>
          <div class="phone-screen-line"></div>
          <div class="phone-screen-btn"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import '../../scripts/smooth-scroll.ts';
</script>
