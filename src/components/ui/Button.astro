---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary';
  type?: 'button' | 'submit';
  class?: string;
  [key: string]: unknown;
}

const {
  href,
  variant = 'primary',
  type = 'button',
  class: className = '',
  ...rest
} = Astro.props;

const classes = `btn btn-${variant} ${className}`.trim();
---

{href ? (
  <a href={href} class={classes} {...rest}>
    <slot />
  </a>
) : (
  <button type={type} class={classes} {...rest}>
    <slot />
  </button>
)}
